{
  "name": "lightspeed-agentic-console-plugin",
  "version": "0.0.1",
  "description": "OpenShift Lightspeed Agentic Console Plugin — proposals UI for AI-driven cluster operations",
  "private": true,
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/openshift/lightspeed-agentic-console.git"
  },
  "scripts": {
    "clean": "rm -rf dist",
    "build": "npm run clean && NODE_ENV=production npm run webpack",
    "build-dev": "npm run clean && npm run webpack",
    "start": "npm run webpack -- serve --progress",
    "start-console": "./start-console.sh",
    "i18n": "./i18n-scripts/build-i18n.sh && node ./i18n-scripts/set-english-defaults.js",
    "lint": "npx eslint src integration-tests --fix && stylelint 'src/**/*.css' --allow-empty-input --fix",
    "test-cypress": "cd integration-tests && cypress open",
    "test-cypress-headless": "cd integration-tests && node --max-old-space-size=4096 ../node_modules/.bin/cypress run --browser ${BRIDGE_E2E_BROWSER_NAME:-electron}",
    "cypress-merge": "mochawesome-merge ./integration-tests/screenshots/cypress_report*.json > ./integration-tests/screenshots/cypress.json",
    "cypress-generate": "marge -o ./integration-tests/screenshots/ -f cypress-report -t 'OpenShift Console Plugin Template Cypress Test Results' -p 'OpenShift Cypress Plugin Template Test Results' --showPassed false --assetsDir ./integration-tests/screenshots/cypress/assets ./integration-tests/screenshots/cypress.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "cypress-postreport": "npm run cypress-merge && npm run cypress-generate",
    "webpack": "node -r ts-node/register ./node_modules/.bin/webpack"
  },
  "dependencies": {
    "@openshift-console/dynamic-plugin-sdk": "4.22.0",
    "@openshift-console/dynamic-plugin-sdk-webpack": "4.22.0",
    "@patternfly/react-charts": "^8.4.1",
    "@patternfly/react-core": "^6.4.3",
    "@patternfly/react-icons": "^6.4.0",
    "@patternfly/react-table": "^6.4.3",
    "copy-webpack-plugin": "^14.0.0",
    "css-loader": "^7.1.4",
    "dompurify": "^3.2.7",
    "i18next": "^26.0.0",
    "marked": "^17.0.5",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-i18next": "~16.5.8",
    "react-router": "~7.13.1",
    "style-loader": "^4.0.0",
    "ts-loader": "^9.6.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3",
    "victory": "^37.3.6",
    "webpack": "^5.106.2",
    "@types/dompurify": "^3.2.0",
    "@types/node": "^22.20.0",
    "@types/react": "^18.3.28",
    "webpack-cli": "^7.0.0"
  },
  "devDependencies": {
    "@cypress/webpack-preprocessor": "^7.0.2",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "cypress": "^15.11.0",
    "cypress-multi-reporters": "^2.0.5",
    "eslint": "^9.7.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-cypress": "^6.1.0",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "globals": "^17.6.0",
    "i18next-parser": "^9.4.0",
    "jsdom": "^26.1.0",
    "mocha": "^11.7.5",
    "mocha-junit-reporter": "^2.2.1",
    "mochawesome": "^7.1.4",
    "mochawesome-merge": "^5.1.1",
    "pluralize": "^8.0.0",
    "prettier": "^3.8.1",
    "stylelint": "^17.4.0",
    "stylelint-config-standard": "^40.0.0",
    "typescript-eslint": "^8.62.0",
    "vitest": "^3.2.4",
    "webpack-dev-server": "^5.2.3"
  },
  "consolePlugin": {
    "name": "lightspeed-agentic-console-plugin",
    "version": "0.0.1",
    "displayName": "OpenShift Lightspeed Agentic Console Plugin",
    "description": "AI-driven proposals UI for OpenShift cluster operations",
    "exposedModules": {
      "ProposalListPage": "./components/proposals/ProposalListPage",
      "ProposalDetailPage": "./components/proposals/ProposalDetailPage",
      "ConfigurationPage": "./components/configuration/ConfigurationPage"
    },
    "dependencies": {
      "@console/pluginAPI": ">=4.22.0-0"
    }
  }
}
